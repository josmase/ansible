{
    "layer": "top",
    "position": "bottom",
    "height": 30,
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["cpu", "memory", "clock"],
    "clock": {
        "format": "{:%Y-%m-%d %H:%M}",
        "tooltip-format": "{:%Y-%m-%d %H:%M:%S}"
    },
    "cpu": {
        "format": " {}%",
        "tooltip": false
    },
    "memory": {
        "format": " {}%",
        "tooltip": false
    }
}
