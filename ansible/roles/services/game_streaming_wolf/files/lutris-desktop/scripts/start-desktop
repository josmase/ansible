#!/bin/bash
set -e

source /opt/gow/bash-lib/utils.sh

export DISPLAY=:0
export GDK_BACKEND=x11
export GTK_THEME=Arc-Dark:dark

# Start Openbox
openbox-session &

# Wait for Openbox to start
sleep 1

# Start tint2 taskbar
tint2 &

# Start PCManFM for desktop icons
pcmanfm --desktop &

gow_log "[desktop] Desktop environment started"

# Keep running
wait
